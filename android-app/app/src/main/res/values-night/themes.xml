<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FixLoop" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/white</item>
        <!-- Customize your theme here. -->
        <item name="android:fontFamily">@font/inter_family</item>

        <item name="materialButtonStyle">@style/BotoPrincipal</item>
    </style>

    <style name="BotoBase" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">45dp</item>
        <item name="android:fontFamily">@font/inter_family</item>
        <item name="android:stateListAnimator">@null</item> <item name="android:insetTop">0dp</item> <item name="android:insetBottom">0dp</item>
    </style>

    <style name="BotoPrincipal" parent="BotoBase">
        <item name="backgroundTint">#008800</item>
        <item name="android:textColor">#FFFFFF</item> </style>

    <style name="BotoSecundari" parent="BotoBase">
        <item name="backgroundTint">#EEEEEE</item>
        <item name="android:textColor">#000000</item> </style>
</resources>